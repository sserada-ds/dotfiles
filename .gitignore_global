# ==============================================
# Global .gitignore
# 全てのリポジトリで無視するファイル
# ==============================================

# ========== OS生成ファイル ==========
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini

# Linux
*~
.directory

# ========== エディタ/IDE ==========
# Vim
*.swp
*.swo
*.swn
*~
.netrwhist

# VSCode
.vscode/
*.code-workspace

# JetBrains (IntelliJ, PyCharm, etc.)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# ========== 環境・機密ファイル ==========
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json
secrets.json

# ========== 依存関係・ビルド ==========
node_modules/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/
*.log

# ========== Claude Code ==========
# プロジェクト指示・計画ファイル（各リポジトリ用）
CLAUDE.md
CLAUDE.local.md
PLAN.md
.claudeignore

# .claude/配下は基本的に無視
.claude/*

# ただし設定、hooks、commandsは追跡する
!.claude/settings.json
!.claude/hooks/
!.claude/commands/

# ========== その他 ==========
# Temporary files
*.tmp
*.temp
*.bak
*.backup

# Archives (自動展開されたもの)
# *.zip
# *.tar.gz
